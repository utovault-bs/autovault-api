# AutoVault Backend Environment Variables
# Ask me (the AI) what each of these means — don't stress about it

DATABASE_URL=postgresql://user:password@localhost:5432/autovault
JWT_SECRET=change-this-to-a-random-string
STRIPE_SECRET_KEY=sk_test_...              # From Stripe dashboard
STRIPE_WEBHOOK_SECRET=whsec_...            # From Stripe dashboard → Webhooks
STRIPE_PRICE_STARTER=price_xxx             # From Stripe dashboard → Products → Starter
STRIPE_PRICE_PRO=price_xxx                 # From Stripe dashboard → Products → Pro
STRIPE_PRICE_ENTERPRISE=price_xxx          # From Stripe dashboard → Products → Enterprise
CLOUDINARY_CLOUD_NAME=your-cloud-name      # From Cloudinary dashboard
CLOUDINARY_API_KEY=123456789               # From Cloudinary dashboard
CLOUDINARY_API_SECRET=abc123               # From Cloudinary dashboard
CLIENT_URL=http://localhost:5173           # Change to https://autovault-web.vercel.app after deploy
PORT=5000
